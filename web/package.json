{
  "name": "hermes-van-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "node --env-file=.env --import tsx src/server/main.ts",
    "hermes-van:start": "node --env-file=.env --import tsx src/server/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env --import tsx scripts/migrate.ts",
    "hermes-van:bootstrap": "node --env-file=.env --import tsx scripts/bootstrap.ts",
    "hermes-van:backup": "node --env-file=.env --import tsx scripts/backup.ts",
    "hermes-van:restore": "node --env-file=.env --import tsx scripts/restore.ts",
    "hermes-van:vapid": "node --import tsx scripts/vapid.ts",
    "hermes-van:import": "node --env-file=.env --import tsx scripts/import-telegram.ts",
    "hermes-van:heal": "node --env-file=.env --import tsx scripts/heal-orphans.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@node-rs/argon2": "^2.0.2",
    "@simplewebauthn/browser": "^11.0.0",
    "@simplewebauthn/server": "^11.0.0",
    "@simplewebauthn/types": "^11.0.0",
    "@types/web-push": "^3.6.4",
    "better-sqlite3": "npm:better-sqlite3-multiple-ciphers@^12.0.0",
    "better-sqlite3-multiple-ciphers": "^12.0.0",
    "dompurify": "^3.4.7",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.16",
    "marked": "^18.0.4",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ulid": "^2.3.0",
    "web-push": "^3.6.7",
    "wouter": "^3.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.18.1",
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.29.1",
    "jsdom": "26.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
