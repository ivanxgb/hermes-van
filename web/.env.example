# hermes-van environment template
# Copy to .env and fill in real values. Never commit .env.
#
# IMPORTANT: All vars are namespaced HERMES_VAN_* to avoid collision
# with HERMES_* vars that the Hermes agent runtime injects into shells.

NODE_ENV=development

# Hermes gateway (api_server platform)
HERMES_VAN_GATEWAY_URL=http://127.0.0.1:8765
HERMES_VAN_GATEWAY_KEY=<paste from ~/.hermes/config.yaml gateway.platforms.api_server.key>

# Local SQLCipher database
HERMES_VAN_DB_PATH=./data/hermes-van.db
# 32 bytes hex (64 chars). Generate: openssl rand -hex 32
HERMES_VAN_DB_KEY=replace-with-32-byte-hex-from-openssl-rand

# Session HMAC signing key. Generate: openssl rand -hex 32
HERMES_VAN_SESSION_SECRET=replace-with-32-byte-hex-from-openssl-rand

# WebAuthn relying party
# In dev: localhost / http://localhost:3015
# In prod: hermes.example.com / https://hermes.example.com
HERMES_VAN_RP_ID=localhost
HERMES_VAN_RP_ORIGIN=http://localhost:3015
HERMES_VAN_RP_NAME=hermes-van

# Bind
HERMES_VAN_PORT=3015
HERMES_VAN_HOST=127.0.0.1

# Log level: fatal | error | warn | info | debug | trace
HERMES_VAN_LOG_LEVEL=info

# Optional web push. Generate with: pnpm hermes-van:vapid
# HERMES_VAN_VAPID_PUBLIC=
# HERMES_VAN_VAPID_PRIVATE=
# HERMES_VAN_VAPID_SUBJECT=mailto:noreply@example.com

# Optional high-severity audit alert webhook.
# HERMES_VAN_ALERT_WEBHOOK=
# HERMES_VAN_ALERT_BEARER=

# Number of encrypted DB backups to keep after successful backup runs.
HERMES_VAN_BACKUP_RETENTION=14
